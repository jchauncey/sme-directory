# SQLite for local dev
DATABASE_URL="file:./dev.db"

# Postgres for prod (uncomment, set provider="postgresql" in prisma/schema.prisma)
# DATABASE_URL="postgresql://user:pass@localhost:5432/sme_directory?schema=public"

# Secret used to sign session JWTs. Generate with: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-32-plus-char-random-string-via-openssl"
